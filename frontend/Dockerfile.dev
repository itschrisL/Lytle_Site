#   ‚Ėą‚Ėą‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚Ėą  ‚Ėą‚Ėą    ‚Ėą‚Ėą  ‚Ėą‚Ėą‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚Ėą‚Ėą   ‚ĖÄ‚ĖÄ‚Ėą‚Ėą‚ĖÄ‚ĖÄ   ‚ĖĄ‚Ėą‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚Ėą            
#  ‚Ėą‚Ėą‚ĖÄ       ‚Ėą‚Ėą    ‚Ėą‚Ėą  ‚Ėą‚Ėą    ‚Ėą‚Ėą     ‚Ėą‚Ėą     ‚Ėą‚Ėą‚ĖĄ                
#  ‚Ėą‚Ėą        ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą      ‚Ėą‚Ėą      ‚ĖÄ‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ            
#  ‚Ėą‚Ėą‚ĖĄ       ‚Ėą‚Ėą    ‚Ėą‚Ėą  ‚Ėą‚Ėą  ‚ĖÄ‚Ėą‚Ėą‚ĖĄ     ‚Ėą‚Ėą          ‚ĖÄ‚Ėą‚Ėą           
#   ‚Ėą‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą  ‚Ėą‚Ėą    ‚Ėą‚Ėą  ‚Ėą‚Ėą    ‚Ėą‚Ėą   ‚ĖĄ‚ĖĄ‚Ėą‚Ėą‚ĖĄ‚ĖĄ   ‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚ĖÄ           
#     ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ   ‚ĖÄ‚ĖÄ    ‚ĖÄ‚ĖÄ  ‚ĖÄ‚ĖÄ    ‚ĖÄ‚ĖÄ‚ĖÄ  ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ    ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖÄ             
#                                                            
#
# Dev-only image ‚ÄĒ just installs deps, source is mounted at runtime.
# No build step: nuxt dev handles compilation on the fly.

FROM node:20-alpine

WORKDIR /app

# Install deps first for layer caching ‚ÄĒ re-runs only when package.json changes
COPY package.json package-lock.json* ./
RUN npm install

EXPOSE 3000

# Command is overridden by docker-compose.dev.yml: npm run dev
CMD ["npm", "run", "dev"]
